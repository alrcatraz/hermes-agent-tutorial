digraph CamofoxCreds {
    rankdir=TB;
    splines=ortho;
    nodesep=0.3;
    ranksep=0.3;
    margin=0.1;
    
    node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=10, height=0.4];
    
    start [label="登录流程", fillcolor="#E5FFE5", color="#22C55E"];
    
    keepass [label="KeePassXC (Web 凭据)", fillcolor="#DEE5F2", color="#3465A4"];
    keepass_search [label="keepassxc-cli search\nCombined.kdbx <站点名>", fillcolor="#F0F4FF", color="#3465A4"];
    keepass_get [label="获取用户名 + 密码", fillcolor="#DEE5F2", color="#3465A4"];
    
    api [label="Camofox REST API", fillcolor="#EDE5FF", color="#8B5CF6"];
    api_nav [label="POST /tabs\n(导航到登录页)", fillcolor="#F5F0FF", color="#8B5CF6"];
    api_fill [label="POST .../type\n(填写凭据)", fillcolor="#F5F0FF", color="#8B5CF6"];
    api_submit [label="POST .../click\n(提交登录)", fillcolor="#F5F0FF", color="#8B5CF6"];
    api_cookie [label="Cookie 自动持久化\n到 profile", fillcolor="#EDE5FF", color="#8B5CF6"];
    
    followup [label="后续访问 (同一 userId)", fillcolor="#E5FFE5", color="#22C55E"];
    auto_load [label="Camofox 自动加载 profile\n→ 已登录状态", fillcolor="#E5FFE5", color="#22C55E"];
    
    start -> keepass;
    start -> api;
    start -> followup;
    
    keepass -> keepass_search -> keepass_get;
    
    api -> api_nav -> api_fill -> api_submit -> api_cookie;
    
    followup -> auto_load;
}