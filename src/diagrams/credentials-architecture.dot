digraph Credentials {
    rankdir=TB;
    splines=ortho;
    nodesep=0.5;
    ranksep=0.3;
    compound=true;
    margin=0.15;
    pad=0.2;
    
    node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=10];
    
    // Outer container
    outer [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#1A1A2E"><FONT COLOR="white"><B>凭据管理架构</B></FONT></TD></TR>
            <TR><TD>
                <TABLE BORDER="0" CELLSPACING="4">
                    <TR>
                        <TD BGCOLOR="#DEE5F2" WIDTH="230" PORT="left">
                            <TABLE BORDER="0" CELLSPACING="2">
                                <TR><TD><B>KeePassXC 系统</B></TD></TR>
                                <TR><TD>Combined.kdbx</TD></TR>
                                <TR><TD>├─ GitHub</TD></TR>
                                <TR><TD>├─ OpenAI API Key</TD></TR>
                                <TR><TD>├─ 网站密码</TD></TR>
                                <TR><TD>└─ ...</TD></TR>
                                <TR><TD HRULES="YES"></TD></TR>
                                <TR><TD>KeePassXC 主密码保护</TD></TR>
                            </TABLE>
                        </TD>
                        <TD WIDTH="20"> </TD>
                        <TD BGCOLOR="#FFF5E5" WIDTH="230" PORT="right">
                            <TABLE BORDER="0" CELLSPACING="2">
                                <TR><TD><B>GPG-encrypted YAML</B></TD></TR>
                                <TR><TD>~/Documents/credentials/</TD></TR>
                                <TR><TD>├─ personal.yaml.gpg</TD></TR>
                                <TR><TD>├─ work.yaml.gpg</TD></TR>
                                <TR><TD>└─ other.yaml.gpg</TD></TR>
                                <TR><TD HRULES="YES"></TD></TR>
                                <TR><TD>.env 对称口令加密</TD></TR>
                                <TR><TD>echo $PASS | gpg ...</TD></TR>
                                <TR><TD>无交互解密</TD></TR>
                            </TABLE>
                        </TD>
                    </TR>
                </TABLE>
            </TD></TR>
        </TABLE>
    >, shape=none, fillcolor=none, color=white];
    
    // Bottom targets
    web_creds [label="Web 服务凭据\n(API Key, Token, 网站密码)", fillcolor="#E5FFE5", color="#22C55E"];
    device_creds [label="设备登录凭据\n(SSH, sudo, 服务器连接信息)", fillcolor="#E5FFE5", color="#22C55E"];
    
    // Arrows from the two systems to their targets
    // Can't directly connect from HTML table ports, so use nodes
    left_label [label="", shape=point, width=0, height=0, style=invis];
    right_label [label="", shape=point, width=0, height=0, style=invis];
    
    // Invisible edges to get two separate down-arrows
    left_label -> web_creds [minlen=1];
    right_label -> device_creds [minlen=1];
    
    // Labels for the two arrows
    {
        rank=same; left_label; right_label;
    }
    
    // Note at bottom
    note [label="两个系统独立运行，互不依赖，各管一类凭据。", shape=note, fillcolor="#F5F0FF", color="#8B5CF6", fontsize=10, height=0.3];
    web_creds -> note [style=invis];
    device_creds -> note;
}