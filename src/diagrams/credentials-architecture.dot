digraph Credentials {
    rankdir=TB;
    node [fontname="sans-serif" fontsize=9];
    edge [fontname="Times,serif" fontsize=8];
    compound=true;

    subgraph cluster_dotenv {
        label="~/.hermes/.env（明文口令容器）";
        fontsize=9; fontcolor="#bf360c";
        color="#e65100"; fillcolor="#fff3e0"; style=filled;
        dotenv [shape=note fillcolor="#ffe0b2" label="GPG_Key_Desktop01=...\nKP_Password=...\n（600 权限，不提交版本管理）"];
    }

    subgraph cluster_credentials {
        label="~/.astra/credentials/（凭据仓库）";
        fontsize=9; fontcolor="#444444";
        color="#666666"; fillcolor="#f0f0f0"; style=filled;

        subgraph cluster_web {
            label="系统一：Web 凭据（KeePassXC）";
            fontsize=9; fontcolor="#f57f17";
            color="#f9a825"; fillcolor="#fff8e1"; style=filled;
            kp [shape=note fillcolor="#fff8e1" fontcolor="#f9a825" label="personal.kdbx\n（单个 vault 文件）\n存储：API Key / 网页密码"];
        }

        subgraph cluster_device {
            label="系统二：设备凭据（GPG 加密 YAML）";
            fontsize=9; fontcolor="#2e7d32";
            color="#43a047"; fillcolor="#e8f5e9"; style=filled;
            gp [shape=note fillcolor="#e8f5e9" fontcolor="#43a047" label="device-credentials.yaml.gpg\n（GPG 对称加密 YAML）\n存储：SSH 密码 / sudo 密码"];
        }
    }

    // Re-route edges to avoid crossing
    dotenv -> kp [color="#f9a825" label="读取 KP_Password\n打开 KeePassXC 数据库" headport=w tailport=sw];
    dotenv -> gp [color="#43a047" label="读取 GPG_Key_Desktop01\n解密 GPG 加密文件" headport=e tailport=se];
}
