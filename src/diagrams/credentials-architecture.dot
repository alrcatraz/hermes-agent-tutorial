digraph Credentials {
    rankdir=TB;
    bgcolor="transparent";
    fontname="sans-serif";
    fontsize=11;
    nodesep=0.4;
    ranksep=0.4;
    splines=ortho;

    node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=9, margin=0.12];

    subgraph cluster_dotenv {
        label="~/.hermes/.env（明文口令容器）";
        style="filled,rounded";
        fillcolor="#FFF3E0";
        color="#E65100";
        fontcolor="#BF360C";
        fontsize=9;

        dotenv [label="GPG_Key_Desktop01=\"...\"\nKP_Password=\"...\"\n（600 权限，不提交版本管理）", fillcolor="#FFE0B2", shape=note];
    }

    subgraph cluster_credentials {
        label="~/.astra/credentials/（凭据仓库）";
        style="filled,rounded";
        fillcolor="#F0F0F0";
        color="#666666";
        fontcolor="#444444";
        fontsize=9;

        subgraph cluster_web {
            label="系统一：Web 凭据（KeePassXC）";
            style="filled,rounded";
            fillcolor="#FFF8E1";
            color="#F9A825";
            fontcolor="#F57F17";
            fontsize=9;

            kp [label="personal.kdbx\n（单个 vault 文件）\n存储：API Key / 网页密码", shape=note, fillcolor="#FFF8E1", color="#F9A825"];
        }

        subgraph cluster_device {
            label="系统二：设备凭据（GPG 加密 YAML）";
            style="filled,rounded";
            fillcolor="#E8F5E9";
            color="#43A047";
            fontcolor="#2E7D32";
            fontsize=9;

            gp [label="device-credentials.yaml.gpg\n（GPG 对称加密 YAML）\n存储：SSH 密码 / sudo 密码", shape=note, fillcolor="#E8F5E9", color="#43A047"];
        }
    }

    dotenv -> kp [label=" 读取 KP_Password\n打开 KeePassXC 数据库", color="#F9A825", fontsize=8];
    dotenv -> gp [label=" 读取 GPG_Key_Desktop01\n解密 GPG 加密文件", color="#43A047", fontsize=8];
}
