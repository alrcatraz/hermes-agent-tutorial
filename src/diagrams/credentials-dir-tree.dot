digraph CredentialsDir {
  rankdir=LR;
  bgcolor="transparent";
  fontname="sans-serif";
  fontsize=10;
  nodesep=0.4;
  splines=ortho;

  node [shape=folder, style="filled,rounded", fontname="monospace, sans-serif", fontsize=9, margin=0.2, fillcolor="#FFF8E1", color="#F9A825"];

  root [label="~/.astra/credentials/"];
  readme [label="README.md（索引，权限 600）"];
  personal [label="personal-credentials.yaml.gpg"];
  work [label="work-credentials.yaml.gpg"];
  other [label="other-credentials.yaml.gpg"];

  { rank=same; readme; personal; work; other; }

  root -> readme [arrowhead=none, fontsize=8];
  root -> personal [arrowhead=none];
  root -> work [arrowhead=none];
  root -> other [arrowhead=none];
}
