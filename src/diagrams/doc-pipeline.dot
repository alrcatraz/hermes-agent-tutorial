digraph DocPipeline {
  rankdir=TB;
  bgcolor="transparent";
  fontname="sans-serif";
  fontsize=10;
  nodesep=0.4;
  ranksep=0.5;
  splines=ortho;

  node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=9, margin=0.15];

  subgraph cluster_source {
    label="Markdown 源码（src/）";
    style="filled,rounded";
    fillcolor="#E3F2FD";
    color="#1565C0";
    fontcolor="#0D47A1";
    fontsize=9;

    index [label="index.md\nintroduction.md", fillcolor="#BBDEFB"];
    v1 [label="volume-1/\n（6 章）", fillcolor="#BBDEFB"];
    v2 [label="volume-2/\n（6 章）", fillcolor="#BBDEFB"];
    v3 [label="volume-3/\n（8 章）", fillcolor="#BBDEFB"];
    appendix [label="appendix/\n（4 篇）", fillcolor="#BBDEFB"];
    diagrams [label="diagrams/\n（SVG 图）", fillcolor="#BBDEFB"];
  }

  split [label="同一套源码\n两条输出管线", fillcolor="#FFF8E1", color="#F9A825", shape=diamond, fontsize=10];

  subgraph cluster_web {
    label="Web 输出";
    style="filled,rounded";
    fillcolor="#F3E5F5";
    color="#8B5CF6";
    fontcolor="#6D28D9";
    fontsize=9;

    mkdocs [label="mkdocs-material\n（MkDocs 构建）", fillcolor="#E9D5FF"];
    web [label="GitHub Pages\n（静态网站）", fillcolor="#D8B4FE"];
  }

  subgraph cluster_pdf {
    label="PDF 输出";
    style="filled,rounded";
    fillcolor="#FFF8E1";
    color="#F9A825";
    fontcolor="#F57F17";
    fontsize=9;

    pandoc [label="Pandoc + Lua filters\n（admonitions / inline-code / \ndiagram-path）", fillcolor="#FFF3CD"];
    latex [label="LuaLaTeX\n（astra-doc-style.sty）", fillcolor="#FFECB3"];
    pdf [label="PDF 文档\n（build/hermes-agent-tutorial.pdf）", fillcolor="#FFE082"];
  }

  index -> split;
  v1 -> split;
  v2 -> split;
  v3 -> split;
  appendix -> split;
  diagrams -> split;

  split -> mkdocs [label=" mkdocs serve / build", fontsize=9];
  mkdocs -> web [label=" 自动部署", fontsize=9];

  split -> pandoc [label=" make pdf", fontsize=9];
  pandoc -> latex [label=" lualatex 编译", fontsize=9];
  latex -> pdf;
}
