digraph KBDecisionTree {
  rankdir=TB;
  bgcolor="transparent";
  fontname="sans-serif";
  fontsize=10;
  nodesep=0.3;
  ranksep=0.4;
  splines=ortho;

  node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=9, margin=0.12];

  start [label="有新信息需要存储？", fillcolor="#E3F2FD", color="#1565C0", shape=diamond, fontsize=10];

  question1 [label="属于哪一类？", fillcolor="#FFF8E1", color="#F9A825", shape=diamond, fontsize=9];

  dynamic [label="动态参考数据\nGateway 消息长度、Provider API、工具坑", fillcolor="#FFF3CD", color="#F9A825"];
  config [label="Hermes 附加配置\nMCP 服务、CLI 工具、端口", fillcolor="#BBDEFB", color="#1565C0"];
  mgmt [label="管理方案与维护日志\n健康检查方案、事件记录", fillcolor="#C8E6C9", color="#43A047"];
  incident [label="SRE 事故记录\n根因分析、修复经验", fillcolor="#FFCDD2", color="#E53935"];

  kb_dynamic [label="dynamic_ref KB\ncron 定期刷新", fillcolor="#FFF3CD", color="#F9A825"];
  kb_config [label="hermes_config KB\n部署时手动更新", fillcolor="#BBDEFB", color="#1565C0"];
  kb_mgmt [label="service_mgmt KB\n运行时自动写入", fillcolor="#C8E6C9", color="#43A047"];
  kb_incident [label="sre_incidents KB\n每次事故后记录", fillcolor="#FFCDD2", color="#E53935"];

  start -> question1;
  question1 -> dynamic [label="动态参考数据"];
  question1 -> config [label="系统配置"];
  question1 -> mgmt [label="管理方案"];
  question1 -> incident [label="事故记录"];

  dynamic -> kb_dynamic;
  config -> kb_config;
  mgmt -> kb_mgmt;
  incident -> kb_incident;
}
