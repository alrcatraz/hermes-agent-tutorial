digraph MarkItDownWorkflow {
  rankdir=LR;
  splines=polyline;
  nodesep=0.3;
  ranksep=0.5;
  node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=10, margin=0.2];
  edge [arrowhead=normal, arrowsize=0.7];

  user [label="用户的请求\n「分析这篇文章」", shape=note, style=filled, fillcolor="#E3F2FD"];

  search [label=<<b>web_search()</b><br/><font point-size="9">使用搜索后端搜索</font>>, fillcolor="#FFF3E0"];
  search_result [label=<<font point-size="9"><i>返回: [{title, url, snippet}, …]</i></font>>, shape=note, style=dashed, fillcolor="#FFFDE7"];

  convert [label=<<b>convert_to_markdown(url)</b><br/><font point-size="9">Agent 自主调用 MCP 工具</font>>, fillcolor="#E8F5E9"];
  markdown [label=<<font point-size="9"><i>返回: 完整 Markdown 内容</i></font>>, shape=note, style=dashed, fillcolor="#F1F8E9"];

  analyze [label=<<b>Agent 分析内容</b><br/><font point-size="9">并回复用户</font>>, fillcolor="#F3E5F5"];

  user -> search;
  search -> search_result;
  search_result -> convert;
  convert -> markdown;
  markdown -> analyze;
  analyze -> user [style=dashed, color=gray, label="回复", constraint=false];
}
