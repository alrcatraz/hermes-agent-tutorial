digraph MarkitdownExtract {
    rankdir=TB;
    bgcolor="transparent";
    fontname="sans-serif";
    fontsize=10;
    nodesep=0.3;
    ranksep=0.4;
    splines=ortho;

    node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=9, margin=0.12];

    web [label="web_extract(urls=[...])\nHermes 内置工具", fillcolor="#E3F2FD", color="#1565C0"];

    dispatch [label="ctx.dispatch_tool(...)\nPlugin 拦截并重定向", fillcolor="#FFF3E0", color="#E65100"];

    mcp [label="markitdown-mcp\nHermes 托管的 MCP 服务器", fillcolor="#E8F5E9", color="#43A047"];

    library [label="Microsoft MarkItDown 库\nHTML → Markdown", fillcolor="#F3E5F5", color="#8B5CF6"];

    ocr [label="GLM-4.6V-Flash OCR\n图片 / 扫描 PDF", fillcolor="#FCE4EC", color="#C62828", style="dashed, filled"];

    output [label="返回 Markdown 文本\n替换 web_extract 结果", fillcolor="#E8F5E9", color="#2E7D32"];

    web -> dispatch [color="#E65100"];
    dispatch -> mcp [color="#43A047"];
    mcp -> library [color="#8B5CF6", label=" HTML 内容", fontsize=8];
    mcp -> ocr [color="#C62828", style=dashed, label=" 需 OCR", fontsize=8];
    library -> output [color="#2E7D32"];
    ocr -> output [color="#2E7D32"];
}
