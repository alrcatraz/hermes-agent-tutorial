digraph PrincipleFlow {
    rankdir=LR;
    splines=ortho;
    nodesep=0.4;
    ranksep=0.6;
    margin=0.1;
    
    node [shape=box, style="filled,rounded", fontname="sans-serif", fontsize=11,
          height=0.5];
    
    principle [label="原则 (抽象)", fillcolor="#FFF5E5", color="#F59E0B"];
    skill [label="Skill (可重复流程)", fillcolor="#EDE5FF", color="#8B5CF6"];
    auto [label="自动加载", fillcolor="#DEE5F2", color="#3465A4"];
    exec [label="每次执行", fillcolor="#E5FFE5", color="#22C55E"];
    
    principle -> skill [label="封装为"];
    skill -> auto [label="触发匹配"];
    auto -> exec [label="注入上下文"];
}